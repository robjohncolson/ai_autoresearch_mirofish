{
  "description": "LLM endpoint configuration for student simulation and optimization",
  "student": {
    "provider": "ollama",
    "endpoint": "http://localhost:11434",
    "model": "qwen3:8b",
    "options": {
      "temperature": 0.8,
      "num_predict_mcq": 5,
      "num_predict_frq": 200
    },
    "think": false,
    "max_concurrent_requests": 5,
    "timeout_seconds": 60
  },
  "optimizer": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "api_key_env": "ANTHROPIC_API_KEY",
    "max_tokens": 4096,
    "temperature": 0.3
  },
  "grading_fallback": {
    "provider": "ollama",
    "endpoint": "http://localhost:11434",
    "model": "qwen3:8b",
    "think": false
  }
}
